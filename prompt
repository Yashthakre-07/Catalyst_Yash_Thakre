# models/skill.py
class SkillAssessment(BaseModel):
    skill_name: str
    required_level: int
    claimed_level: int
    assessed_level: int
    gap_score: int
    category: Literal["STRONG", "DEVELOPING", "GAP"]
    assessment_reasoning: str

# models/candidate.py
class CandidateProfile(BaseModel):
    name: str
    current_role: str
    years_experience: int
    skills_from_resume: list[str]
    resume_text: str

# models/learning_plan.py
class Resource(BaseModel):
    title: str
    url: str
    type: Literal["course", "article", "project", "book", "video"]
    estimated_hours: int
    why_recommended: str

class SkillPlan(BaseModel):
    skill_name: str
    current_level: int
    target_level: int
    resources: list[Resource]
    estimated_weeks: int
    weekly_breakdown: list[str]
    adjacent_to: Optional[str] = None

class LearningPlan(BaseModel):
    candidate_name: str
    target_role: str
    assessment_date: str
    total_duration_weeks: int
    skill_plans: list[SkillPlan]
    priority_order: list[str]
    skills_strong: list[str]
    summary: str

